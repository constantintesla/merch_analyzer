SKU110K_REPO_PATH=third_party/SKU110K_CVPR19
SKU110K_WEIGHTS_PATH=models/sku110k_pretrained.h5
SKU110K_PYTHON_BIN=.venv_sku/Scripts/python.exe
# docker — удобно для TF 1.15, но каждый кадр = старт контейнера (медленнее).
# native / wsl — быстрее при уже подготовленном Python с зависимостями SKU110K (см. README).
# auto — выбор docker > wsl > native по наличию команд.
SKU110K_RUN_MODE=docker
SKU110K_WSL_PYTHON_BIN=python3
SKU110K_DOCKER_IMAGE=merch-analyzer-sku110k:tf1.15
SKU110K_DOCKER_MOUNT_HOST=.
SKU110K_DOCKER_MOUNT_TARGET=/workspace
SKU110K_DOCKER_USE_GPU=true
SKU110K_SCORE_THRESHOLD=0.3

# Используется только в старой логике; в новой логике полки определяются автоматически.
SHELF_ROWS=4
SIMILARITY_THRESHOLD=0.88

LMSTUDIO_URL=http://desktop-oh7jn1i:1234
LMSTUDIO_MODEL=qwen/qwen3.5-35b-a3b
# Таймаут одного запроса к LM Studio (сек). На шаге /recognize запросов много (по числу позиций).
LMSTUDIO_TIMEOUT_SEC=25
# Параллельные classify_crop на шаге /recognize (1 = по очереди; 2–4 — осторожно с VRAM на одной GPU).
LM_CONCURRENT=1
# Один запрос LM с несколькими кропами (JSON results[{slot,line}]). Имеет приоритет над LM_SHARED_CLASSIFY_PER_SIMILARITY_GROUP.
# Повторный запрос LM_RECHECK_UNKNOWN на кроп не применяется в этом режиме. По умолчанию в коде — true (быстрее per-crop).
LM_BATCH_CLASSIFY_SINGLE_REQUEST=true
# Макс. кропов в одном batch-запросе (дальше — несколько запросов подряд).
LM_BATCH_MAX_CROPS_PER_REQUEST=12
# Лимит max_tokens для batch (пусто = max(LM_CLASSIFY_MAX_TOKENS, 256+128*N)).
LM_BATCH_CLASSIFY_MAX_TOKENS=
# Макс. длинная сторона кропа перед LM (0 = не уменьшать). 384–512 ускоряет vision, мелкий текст может пострадать.
LM_CROP_MAX_SIDE=0
# Качество JPEG в data URL для кропа (40–95).
LM_CROP_JPEG_QUALITY=88
# Лимит токенов ответа для classify_crop (think/VLM часто дают длинный текст до JSON). 0 = не задавать max_tokens.
LM_CLASSIFY_MAX_TOKENS=2048
# Повторный запрос LM для позиций с unknown / ошибкой / uncertain (1 = включено).
LM_RECHECK_UNKNOWN=1
# Если 1 — повторять и для ответа «Ничего не обнаружено» (лишний вызов API).
LM_RECHECK_NOTHING_DETECTED=0
# Ограничить число позиций для LM на шаге 2 (0 = без лимита). Резервное имя: LM_ASSESS_MAX_POSITIONS.
LM_RECOGNIZE_MAX_POSITIONS=0
# true — один vision-запрос на кластер похожих bbox (быстрее; риск одного имени на разные SKU).
# false — запрос на каждую позицию (по умолчанию, точнее).
LM_SHARED_CLASSIFY_PER_SIMILARITY_GROUP=false

# Каталог канонических названий SKU (стабилизация подписей LM и сравнение с планограммой).
# Форматы: JSON-массив строк; CSV с колонкой name или sku_name; либо текстовый файл по одному имени в строке (# — комментарий).
# Пустой путь — каталог не используется, имена остаются как вернул LM (плюс унификация внутри кластера похожих кропов).
ASSORTMENT_CATALOG_PATH=

# Порог схожести строки LM с именем из каталога (0..1). Выше — строже, ниже — больше автоподстановок канона.
CATALOG_MATCH_THRESHOLD=0.82

# Насколько имя позиции должно быть похоже на «большинство» в группе похожих кропов (предупреждение group_conflict).
GROUP_CONSISTENCY_THRESHOLD=0.45
LM_LOW_CONFIDENCE_THRESHOLD=0.55
